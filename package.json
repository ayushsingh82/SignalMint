{
  "name": "signal-mint",
  "version": "1.0.0",
  "private": true,
  "description": "SignalMint: Autonomous multi-agent system for Protocol Labs Synthesis 2026",
  "main": "dist/src/index.js",
  "scripts": {
    "skill:fetch": "curl -s https://synthesis.devfolio.co/skill.md -o md/skill.md",
    "dev": "next dev",
    "build": "npm run agent:build && next build",
    "start": "next start",
    "lint": "eslint",
    "agent:build": "tsc",
    "agent:dev": "ts-node --transpile-only --compiler-options '{\"module\":\"commonjs\",\"moduleResolution\":\"node\"}' src/agents/main.ts",
    "agent:run": "node dist/src/agents/main.js",
    "agent:watch": "tsc --watch",
    "art:preview": "ts-node --transpile-only --compiler-options '{\"module\":\"commonjs\",\"moduleResolution\":\"node\"}' src/scripts/preview-three-nft-styles.ts",
    "mint:three": "ts-node --transpile-only --compiler-options '{\"module\":\"commonjs\",\"moduleResolution\":\"node\"}' src/scripts/mint-three-onchain.ts",
    "test": "jest",
    "test:e2e": "jest --testMatch='**/*.e2e.test.ts'",
    "clean": "rm -rf dist/ logs/"
  },
  "keywords": [
    "synthesis",
    "ai-agents",
    "hackathon",
    "signal-mint",
    "rare-protocol",
    "protocol-labs",
    "erc-8004",
    "filecoin",
    "uniswap",
    "autonomous-agents"
  ],
  "author": "SignalMint Contributors",
  "license": "MIT",
  "dependencies": {
    "@openserv-labs/client": "^2.5.3",
    "@openserv-labs/sdk": "^2.4.1",
    "@rareprotocol/rare-cli": "^0.3.0",
    "@zyfai/sdk": "^0.2.26",
    "axios": "^1.13.6",
    "dotenv": "^16.6.1",
    "ethers": "^6.9.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "viem": "^2.47.5",
    "web3.storage": "^4.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/jest": "^29.5.5",
    "@types/node": "^20.8.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jest": "^29.7.0",
    "jest-extended": "^4.0.2",
    "tailwindcss": "^4",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
