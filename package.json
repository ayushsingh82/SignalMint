{
  "name": "signal-mint",
  "version": "1.0.0",
  "private": true,
  "description": "SignalMint: Autonomous multi-agent system for Protocol Labs Synthesis 2026",
  "main": "dist/src/index.js",
  "scripts": {
    "skill:fetch": "curl -s https://synthesis.devfolio.co/skill.md -o md/skill.md",
    "dev": "next dev",
    "build": "npm run agent:build && next build",
    "start": "next start",
    "lint": "eslint",
    "agent:build": "tsc",
    "agent:dev": "ts-node --transpile-only --compiler-options '{\"module\":\"commonjs\",\"moduleResolution\":\"node\"}' src/agents/main.ts",
    "agent:run": "node dist/src/agents/main.js",
    "agent:watch": "tsc --watch",
    "test": "jest",
    "test:e2e": "jest --testMatch='**/*.e2e.test.ts'",
    "clean": "rm -rf dist/ logs/"
  },
  "keywords": [
    "synthesis",
    "ai-agents",
    "hackathon",
    "signal-mint",
    "rare-protocol",
    "protocol-labs",
    "erc-8004",
    "filecoin",
    "uniswap",
    "autonomous-agents"
  ],
  "author": "SignalMint Contributors",
  "license": "MIT",
  "dependencies": {
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "axios": "^1.6.2",
    "dotenv": "^16.3.1",
    "ethers": "^6.9.0",
    "viem": "^1.17.0",
    "web3.storage": "^4.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/jest": "^29.5.5",
    "@types/node": "^20.8.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jest": "^29.7.0",
    "jest-extended": "^4.0.2",
    "tailwindcss": "^4",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
