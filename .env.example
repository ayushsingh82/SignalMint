# ============================================================================
# SignalMint Agent Configuration
# Copy this to .env and fill in your values
# ============================================================================

# ============================================================================
# AGENT IDENTITY (Required)
# ============================================================================
# Private key for agent wallet (Sepolia testnet recommended)
# Format: 0x<64-hex-chars>
AGENT_PRIVATE_KEY=0x

# Optional: Agent name for logging
AGENT_NAME=SignalMint-1

# Optional: Agent version
AGENT_VERSION=1.0.0

# ============================================================================
# BLOCKCHAIN RPC ENDPOINTS (Optional - uses public fallbacks if not set)
# ============================================================================
# Sepolia testnet (recommended for development)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# Mainnet (for production)
MAINNET_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY

# Base network
BASE_RPC_URL=https://mainnet.base.org

# ============================================================================
# PROTOCOL INTEGRATIONS
# ============================================================================

# --- Rare Protocol (Required for NFT minting) ---
# CLI automatically detects from system installation
# To set custom path (optional):
RARE_CLI_PATH=/usr/local/bin/rare

# Chain for Rare deployments: sepolia, mainnet, base
RARE_CHAIN=sepolia

# Optional: Pre-deployed collection address
# If not set, agent deploys new collection on first run
RARE_COLLECTION_ADDRESS=0x

# --- Uniswap V4 (For price feeds & swaps) ---
# Get API key: https://developers.uniswap.org
UNISWAP_API_KEY=

# Optional: Override Uniswap API endpoint
UNISWAP_API_URL=https://api.uniswap.org/v1

# --- Filecoin/IPFS (For log persistence) ---
# Get token: https://web3.storage
WEB3_STORAGE_TOKEN=

# Optional: IPFS gateway for reading logs
IPFS_GATEWAY_URL=https://w3s.link/ipfs

# ============================================================================
# SIGNAL DETECTION THRESHOLDS
# ============================================================================
# ETH price threshold for triggering signals (USD)
SIGNAL_ETH_PRICE_THRESHOLD=2500

# Minimum confidence score to execute decision (0.0 - 1.0)
SIGNAL_CONFIDENCE_THRESHOLD=0.8

# Check price every N milliseconds
SIGNAL_PRICE_CHECK_INTERVAL_MS=5000

# For high-confidence signals (> 0.9), execute additional action
SIGNAL_HIGH_CONFIDENCE_THRESHOLD=0.9

# ============================================================================
# EXECUTION CONFIGURATION
# ============================================================================
# Whether to actually execute transactions (set to false for dry-run)
EXECUTION_DRY_RUN=false

# Maximum gas price in Gwei (for safety limits)
EXECUTION_MAX_GAS_PRICE_GWEI=100

# Maximum gas per transaction
EXECUTION_MAX_GAS_LIMIT=5000000

# ============================================================================
# COMPUTE BUDGET & RATE LIMITING
# ============================================================================
# Maximum RPC calls per cycle
COMPUTE_MAX_CALLS_PER_CYCLE=100

# Maximum cycle duration in milliseconds (5 minutes)
COMPUTE_MAX_CYCLE_DURATION_MS=300000

# Rate limit: milliseconds between RPC calls
COMPUTE_RPC_CALL_INTERVAL_MS=100

# ============================================================================
# LOGGING & PERSISTENCE
# ============================================================================
# Log directory for agent_log_*.json files
LOG_DIRECTORY=./logs

# Log level: trace, debug, info, warn, error
LOG_LEVEL=info

# Whether to upload logs to Filecoin (requires WEB3_STORAGE_TOKEN)
LOG_UPLOAD_TO_IPFS=true

# Retention: keep logs for this many days
LOG_RETENTION_DAYS=30

# ============================================================================
# ERC-8004 AGENT IDENTITY REGISTRY (For future integration)
# ============================================================================
# Address of ERC-8004 Identity Registry contract
# ERC8004_IDENTITY_REGISTRY=0x

# Whether to register agent on-chain at startup
# ERC8004_AUTO_REGISTER=false

# ============================================================================
# DEVELOPMENT & DEBUG
# ============================================================================
# Enable debug logging
DEBUG=false

# Pretty-print JSON logs (human readable instead of compact)
PRETTY_LOGS=true

# Send test transaction on startup to verify RPC connectivity
CONNECTIVITY_CHECK=true

# ============================================================================
# ANALYTICS & MONITORING (Optional)
# ============================================================================
# Webhook for agent activity notifications
# WEBHOOK_URL=https://...

# Slack webhook for alerts
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ============================================================================
# NOTES
# ============================================================================
# 1. AGENT_PRIVATE_KEY is required. All others have sensible defaults.
# 2. For testing/demo, use mock data (Uniswap/IPFS have graceful fallbacks)
# 3. For mainnet, use testnet first to verify behavior
# 4. Never commit .env file to repository (add to .gitignore)
# 5. See md/IMPLEMENTATION_GUIDE.md for detailed setup instructions
